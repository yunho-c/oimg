flutter_app:
  command: oimg
  arch: @FLUTTER_ARCH@
  parent: /opt
  nonInteractive: true
  execFieldCodes: F

control:
  Package: oimg
  Version: @VERSION@
  Architecture: @DEBIAN_ARCH@
  Priority: optional
  Depends: @DEPENDS@
  Maintainer: OIMG Maintainers
  Description: Image compression tool

options:
  exec_out_dir: debian/packages
